# =============================================================================
# KONTi Dashboard — environment variables
# =============================================================================
# Copy this file to `.env` for local dev. For production:
#   - Vercel dashboard env-vars   →  VITE_* values + DASHBOARD_BASE_URL
#   - Railway api-server env-vars →  everything else
#   - Neon Postgres                →  DATABASE_URL
#
# Required vars are flagged [REQUIRED]. The app fails to boot without them.
# Optional vars degrade gracefully (e.g. AI features turn off without keys).

# --- Core (api-server) -------------------------------------------------------

# [REQUIRED] HTTP port. Railway sets this automatically; locally use 8080.
PORT=8080

# [REQUIRED] JWT signing secret. Min 32 chars. Generate with:
#   node -e "console.log(crypto.randomBytes(48).toString('base64'))"
JWT_SECRET=replace-me-with-48-bytes-of-random-base64

# [REQUIRED in prod, optional in dev] Neon Postgres connection string.
# Use the pooled connection string from Neon's dashboard (ends with -pooler).
# Without this, the api-server runs in seed-only / in-memory mode (dev only).
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/konti?sslmode=require

# [REQUIRED in prod] "production" for Railway/Vercel, "development" locally,
# "test" inside the test harness. Drives fail-fast behavior in bootstrap.
NODE_ENV=production

# Pino log level. Default `info`. Set to `debug` while troubleshooting.
LOG_LEVEL=info

# Where the api-server expects the dashboard to live, used in transactional
# email links + PDF report headers. Production: your Vercel URL.
DASHBOARD_BASE_URL=https://app.konti.com

# --- AI providers ------------------------------------------------------------
# All three keys are also editable at runtime via /integrations (managed
# secrets). Setting them here is the bootstrap / default.

# Anthropic Claude — used by AI chat + receipt line-item extraction.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used as a fallback for AI chat + Whisper audio transcription (P3.3).
OPENAI_API_KEY=sk-...

# PDF.co — used for receipt OCR (P5.1) + server-side PDF report rendering.
PDF_CO_API_KEY=...

# Optional: Perplexity (if you wire it to a route).
PERPLEXITY_API_KEY=

# Optional: Gamma — used by the gamma-report integration.
GAMMA_APP_KEY=

# --- Email (Resend) ----------------------------------------------------------
# Resend handles transactional emails: phase kickoffs, inspection reports,
# client review notifications. The `from` address must be on a verified domain.
RESEND_API_KEY=re_...
MAIL_FROM=KONTi Dashboard <no-reply@konti.com>

# --- Google Drive / Asana ----------------------------------------------------
# Drive doc sync + Asana task sync. Both also editable via /integrations.
# Leave blank in dev to disable.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
ASANA_ACCESS_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_BOARD_GID=

# --- Persistence (dev only — production uses DATABASE_URL) ------------------
# Where the JSON shim store writes when DATABASE_URL is absent. Defaults to
# `artifacts/api-server/.data/`. Honored by lifecycle-store, audit-store,
# integrations-config, estimating-store, punchlist-store.
KONTI_DATA_DIR=

# --- Vercel-only: dashboard env (these go in Vercel's env-vars UI) ----------
# The Vercel build doesn't need these in this file — listed for completeness.
# Set them on the Vercel project settings page.
#
# VITE_API_BASE_URL=https://your-railway-api.up.railway.app
# BASE_PATH=/
