{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "//": "Vercel deploys the konti-dashboard (Vite SPA). The api-server lives on Railway — see DEPLOYMENT.md.",

  "buildCommand": "pnpm --filter @workspace/konti-dashboard run build",
  "outputDirectory": "artifacts/konti-dashboard/dist/public",
  "installCommand": "npm install -g pnpm@11.1.1 && pnpm install --frozen-lockfile",
  "framework": null,

  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR-RAILWAY-API.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
